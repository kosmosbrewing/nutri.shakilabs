{
  "name": "nutri-shakilabs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "fetch:data": "node scripts/fetch-public-data.mjs",
    "fetch:food-safety": "node scripts/fetch-food-safety-data.mjs",
    "fetch:unit-price-evidence": "node scripts/fetch-unit-price-evidence.mjs",
    "unit-price:build": "node scripts/build-unit-price-dataset.mjs",
    "query:food-safety": "node scripts/query-food-safety-product.mjs",
    "catalog:build": "node scripts/build-category-catalog.mjs",
    "catalog:verify": "node scripts/verify-category-catalog.mjs",
    "validate:data": "node scripts/validate-all-data.mjs",
    "build": "npm run catalog:verify && vite-ssg build && npm run verify:static",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"scripts/**/*.mjs\"",
    "lint:layers": "eslint \"src/{data,utils,composables,components,views}/**/*.{ts,vue}\" --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:static": "node scripts/verify-static.mjs",
    "check": "npm run release:check",
    "release:check": "npm run lint && npm run lint:layers && npm run typecheck && npm test && npm run validate:data && npm run build && npm audit --audit-level=high",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.25",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.38.0",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^2.2.0"
  }
}
